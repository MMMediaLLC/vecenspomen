{
  "redirects": [
    { "source": "/pochinati", "destination": "/spomeni", "permanent": true },
    { "source": "/pochinati/:city", "destination": "/spomeni/:city", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/check-reminders",
      "schedule": "0 9 * * *"
    }
  ]
}
