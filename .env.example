# ============================
# ВЕЧЕН СПОМЕН — Environment Variables
# ============================
# Копирајте го овој фајл во .env и пополнете ги вредностите.

# --- Gemini AI (задолжително за AI генерација на текст) ---
# Добијте го на: https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# --- Cloudinary (за прикачување на фотографии) ---
# 1. Регистрирајте се бесплатно на: https://cloudinary.com
# 2. Одете на Settings > Upload > Add upload preset
# 3. Поставете го на "Unsigned" и зачувајте
# 4. Пополнете ги вредностите подолу:
VITE_CLOUDINARY_CLOUD_NAME="YOUR_CLOUD_NAME"
VITE_CLOUDINARY_UPLOAD_PRESET="YOUR_UPLOAD_PRESET"

# --- Lemon Squeezy (Server-side — без VITE_ prefix, не се изложуваат во browser) ---
# Добијте ги од Lemon Squeezy Dashboard
LEMON_STORE_ID="вашиот_store_id"
LEMON_API_KEY="вашиот_api_key"
LEMON_BASIC_VARIANT_ID="variant_id_за_основен"
LEMON_FEATURED_VARIANT_ID="variant_id_за_истакнат"
LEMON_WEBHOOK_SECRET="вашиот_webhook_secret"

# Тајна за internal API повици (генерирај со: openssl rand -hex 32)
INTERNAL_API_SECRET="случаен_долг_стринг_32_карактери"

# --- Firebase Admin (Server-side) ---
# Генерирајте JSON во Firebase Console > Project Settings > Service Accounts
# Поставете го целиот JSON како стринг овде (или во Vercel Environment Variables)
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# --- Апликација ---
# URL каде е хостирана апликацијата (за OG тагови, линкови)
VITE_APP_URL="http://localhost:3000"

# --- Resend (Email нотификации) ---
# 1. Регистрирајте се бесплатно на: https://resend.com
# 2. Создадете API Key
# 3. Верификувајте го вашиот домен (vecenspomen.mk) или користете го Resend test доменот
RESEND_API_KEY="re_xxxxxxxxxxxx"

# E-пошта на администраторот (ќе добивате нотификации за нови objavi)
ADMIN_EMAIL="вашата@email.com"

# From адреса (мора да биде на верификуван домен во Resend)
# За тестирање може да се остави празно — ќе се користи noreply@vecenspomen.mk
RESEND_FROM_EMAIL="Вечен Спомен <noreply@vecenspomen.mk>"
