# ============================
# ВЕЧЕН СПОМЕН — Environment Variables
# ============================
# Копирајте го овој фајл во .env и пополнете ги вредностите.

# --- Gemini AI (задолжително за AI генерација на текст) ---
# Добијте го на: https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# --- Cloudinary (за прикачување на фотографии) ---
# 1. Регистрирајте се бесплатно на: https://cloudinary.com
# 2. Одете на Settings > Upload > Add upload preset
# 3. Поставете го на "Unsigned" и зачувајте
# 4. Пополнете ги вредностите подолу:
VITE_CLOUDINARY_CLOUD_NAME="YOUR_CLOUD_NAME"
VITE_CLOUDINARY_UPLOAD_PRESET="YOUR_UPLOAD_PRESET"

# --- Апликација ---
# URL каде е хостирана апликацијата (за OG тагови, линкови)
VITE_APP_URL="http://localhost:3000"
